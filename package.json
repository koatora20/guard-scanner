  },
  "homepage": "https://github.com/koatora20/guard-scanner",
  "files": [
    "src/",
    "hooks/",
    "docs/",
    "openclaw.plugin.json",
    "SKILL.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
